generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Review {
  id              String   @id @default(cuid())
  customer        String
  customerMessage String
  suggestedReply  String
  type            String
  status          String   @default("pending")
  createdAt       DateTime @default(now())
}
